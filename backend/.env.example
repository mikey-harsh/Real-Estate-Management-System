# ==========================================
# BuildEstate Backend Environment Variables
# ==========================================

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=4000
NODE_ENV=development
BACKEND_URL="http://localhost:4000"


# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# Local MongoDB
MONGO_URI="mongodb://localhost:27017/buildestate"


# ===========================================
# AUTHENTICATION & SECURITY
# ===========================================
JWT_SECRET="buildestate_dev_jwt_secret_local_2024_super_secure"


# ===========================================
# EMAIL CONFIGURATION
# ===========================================
SMTP_USER=""
SMTP_PASS=""
EMAIL=""
EMAIL_USER=""
BREVO_API_KEY=""

# Admin Account Credentials
ADMIN_EMAIL="admin@buildestate.com"
ADMIN_PASSWORD="Admin@123456"


# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
WEBSITE_URL="http://localhost:5173"
FRONTEND_URL="http://localhost:5173"
ADMIN_URL="http://localhost:5174"
LOCAL_URLS="http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177,http://localhost:4000"
EXTRA_ALLOWED_ORIGINS=""


# ===========================================
# IMAGE STORAGE (Optional)
# ===========================================
IMAGEKIT_PUBLIC_KEY=""
IMAGEKIT_PRIVATE_KEY=""
IMAGEKIT_URL_ENDPOINT=""


# ===========================================
# AI SERVICES (Optional)
# ===========================================
